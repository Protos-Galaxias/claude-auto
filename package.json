{
  "name": "claude-auto",
  "version": "1.0.0",
  "description": "Automatic Claude Code re-authentication — CLI and library",
  "type": "module",
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib.js",
      "types": "./dist/lib.d.ts"
    }
  },
  "bin": {
    "claude-auto": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "tsc && node --test dist/__tests__/",
    "prepare": "tsc",
    "postinstall": "npx playwright install chromium"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "node-pty": "^1.1.0",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
